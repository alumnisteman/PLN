# ─── Environment ──────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ─── Backend (Laravel) ────────────────────────────────────────────
backend/vendor/
backend/.env
backend/.env.*
!backend/.env.example
backend/storage/logs/*.log
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/testing/*
backend/storage/framework/views/*
backend/bootstrap/cache/*.php
backend/public/hot
backend/public/storage

# ─── Frontend (Next.js) ───────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/.env.local
frontend/.env.*.local
frontend/packages/*/node_modules/

# ─── Docker ───────────────────────────────────────────────────────
# (docker-compose.yml tetap ditrack)

# ─── Storage & Backup ─────────────────────────────────────────────
storage/app/private/*
storage/logs/*
backup/database/*
backup/storage/*
!storage/app/private/.gitkeep
!storage/logs/.gitkeep
!backup/database/.gitkeep
!backup/storage/.gitkeep

# ─── OS & Editor ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.log
